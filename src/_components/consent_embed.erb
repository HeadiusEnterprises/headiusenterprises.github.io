<div class="consent-embed-wrap<%= " consent-embed-wrap--#{variant}" if variant %>">
  <div class="consent-embed<%= " consent-embed--#{variant}" if variant %>" data-provider="<%= provider %>"<% if embed_url %> data-embed-url="<%= embed_url %>"<% end %><% if script_url %> data-script-url="<%= script_url %>"<% end %><% if background %> style="background-image: url('<%= background %>')"<% end %>>
    <button class="consent-embed__play" aria-label="<%= play_label %>">
      <% if provider == "Reddit" %>
        <svg class="consent-embed__icon consent-embed__icon--reddit" viewBox="0 0 512 512" width="48" height="48" aria-hidden="true">
          <path fill="#FF4500" d="M201.5 305.5c-13.8 0-24.9-11.1-24.9-24.6 0-13.8 11.1-24.9 24.9-24.9 13.6 0 24.6 11.1 24.6 24.9 0 13.6-11.1 24.6-24.6 24.6zM504 256c0 137-111 248-248 248S8 393 8 256 119 8 256 8s248 111 248 248zm-132.3-41.2c-9.4 0-17.7 3.9-23.8 10-22.4-15.5-52.6-25.5-86.1-26.6l17.4-78.3 55.4 12.5c0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.3 24.9-24.9s-11.1-24.9-24.9-24.9c-9.7 0-18 5.8-22.1 13.8l-61.2-13.6c-3-.8-6.1 1.4-6.9 4.4l-19.1 86.4c-33.2 1.4-63.1 11.3-85.5 26.8-6.1-6.4-14.7-10.2-24.1-10.2-34.9 0-46.3 46.9-14.4 62.8-1.1 5-1.7 10.2-1.7 15.5 0 52.6 59.2 95.2 132.1 95.2 73.2 0 132.4-42.6 132.4-95.2 0-5.3-.6-10.8-1.9-15.8 31.3-16 19.8-62.5-14.9-62.5zM302.8 331c-18.2 18.2-76.1 17.9-93.6 0-2.2-2.2-6.1-2.2-8.3 0-2.5 2.5-2.5 6.4 0 8.6 22.8 22.8 87.3 22.8 110.2 0 2.5-2.2 2.5-6.1 0-8.6-2.2-2.2-6.1-2.2-8.3 0zm7.7-75.5c-13.6 0-24.6 11.1-24.6 24.9 0 13.6 11.1 24.6 24.6 24.6 13.8 0 24.9-11.1 24.9-24.6 0-13.9-11-24.9-24.9-24.9z"/>
        </svg>
      <% else %>
        <svg class="consent-embed__icon consent-embed__icon--play" viewBox="0 0 68 48" width="68" height="48" aria-hidden="true">
          <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="var(--crimson)"/>
          <path d="M45 24L27 14v20" fill="var(--on-crimson)"/>
        </svg>
      <% end %>
      <span class="consent-embed__tooltip">Loading will fetch content from <%= provider %> and set cookies. <a href="<%= privacy_url %>" target="_blank" rel="noopener">Privacy Policy</a></span>
    </button>
    <% if script_url && content.to_s.strip != "" %>
      <template class="consent-embed__template"><%= content %></template>
    <% end %>
  </div>
  <span class="consent-embed__title"><%= title %></span>
  <a class="consent-embed__link" href="<%= link_url %>" target="_blank" rel="noopener"><%= link_label %></a>
</div>
