---
layout: default
title: Contact
---

<!-- ===== Intro ===== -->
<section id="contact-intro">
  <div class="container">
    <pre><code class="highlight"><span class="k">require</span> <span class="s">'headius/contact'</span></code></pre>
    <hgroup>
      <h1>Get In Touch</h1>
      <p>Whether you want to talk about JRuby support, have us speak at your event, or just want to say hello at a conference — we'd love to hear from you.</p>
    </hgroup>
  </div>
</section>

<!-- ===== Contact Details + Form ===== -->
<section class="highlight" id="contact-details">
  <div class="container">
    <div class="two-col">
      <div>
        <pre><code class="highlight"><span class="c"># == Headius::Contact</span>
<span class="c"># The direct route. No ticket queue.</span></code></pre>
        <h2>Direct Contact</h2>
        <p>If you'd rather skip the form, reach us directly. The person who reads your email is the same person who'll commit the fix.</p>
        <%= render ListTable.new do %>
          <li>
            <span class="label">email</span>
            <a href="mailto:<%= site.metadata.email %>"><%= site.metadata.email %></a>
          </li>
          <li>
