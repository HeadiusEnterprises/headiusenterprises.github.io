            <a href="https://github.com/jruby/" target="_blank" rel="noopener"><svg class="icon" viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.237 1.838 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.898-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg> jruby</a>
          </li>
          <li>
            <span class="label">web</span>
            <span><a href="https://jruby.org" target="_blank" rel="noopener">JRuby.org</a></span>
          </li>
        <% end %>
      </div>
      <div>
        <p><em>All fields are optional — share only what's useful.</em></p>
        <form class="highlight" action="#" method="post" onsubmit="return handleContactForm(this)">
          <code class="contact__form-header"><span class="k">Headius</span>::<span class="nc">Inquiry</span>.new <span class="k">do</span> |f|</code>
          <div>
            <label for="inquiry-name">f.name</label>
            <input type="text" id="inquiry-name" name="name" />
          </div>
          <div>
            <label for="inquiry-company">f.company</label>
            <input type="text" id="inquiry-company" name="company" />
          </div>
          <div>
            <label for="inquiry-role">f.role</label>
            <select id="inquiry-role" name="role">
              <option value="">:select_one</option>
              <option value="technical">:technical</option>
              <option value="decision_maker">:decision_maker</option>
              <option value="both">:both</option>
            </select>
          </div>
          <div>
            <label for="inquiry-interest">f.how_can_we_serve_you</label>
            <select id="inquiry-interest" name="interest">
              <option value="">:select_one</option>
              <option value="getting_started">:i_am_new_to_jruby_need_help_getting_started</option>
              <option value="expert_help">:my_jruby_app_needs_expert_help_and_support</option>
              <option value="sponsoring">:i_want_to_sponsor_developers_or_resources</option>
              <option value="other">:something_else_entirely</option>
            </select>
          </div>
          <div>
            <label for="inquiry-timeline">f.timeline</label>
            <select id="inquiry-timeline" name="timeline">
              <option value="">:select_one</option>
              <option value="immediate">:immediate</option>
              <option value="weeks">:weeks</option>
              <option value="months">:months</option>
              <option value="exploring">:just_exploring</option>
            </select>
          </div>
          <div>
            <label for="inquiry-message">f.about_your_application</label>
            <div class="message-wrap">
              <textarea id="inquiry-message" name="message" rows="10" maxlength="1600" placeholder="Tell us about your application — JRuby/Ruby/JVM versions, app type (Rails, Sinatra, Sidekiq, embedded…), deployment (on-prem, cloud, containers…), and anything else useful."></textarea>
              <span class="char-count" hidden></span>
            </div>
          </div>
          <button type="submit">f.submit!</button>
        </form>
      </div>
    </div>
  </div>
</section>
