            <span class="label">code</span>
            <span><a href="https://jruby.org" target="_blank" rel="noopener">JRuby.org</a></span>
          </li>
        <% end %>
      </div>
      <div>
        <h2>Inquiry Form</h2>
        <div class="consent-embed consent-embed--form" data-provider="Google" data-embed-url="https://docs.google.com/forms/d/e/1FAIpQLSf5vtH39Dj4hLE2DhjAruexEqbteIRiKecX6DRfVI9PfHnTGQ/viewform?embedded=true">
