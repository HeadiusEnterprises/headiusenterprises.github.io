          <span class="consent-embed__title">Click to load the inquiry form</span>
          <a class="consent-embed__link" href="https://docs.google.com/forms/d/e/1FAIpQLSf5vtH39Dj4hLE2DhjAruexEqbteIRiKecX6DRfVI9PfHnTGQ/viewform" target="_blank" rel="noopener">Open form on Google</a>
