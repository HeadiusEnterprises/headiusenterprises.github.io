              <path d="M28 16h4l2 2h6a2 2 0 012 2v10a2 2 0 01-2 2H28a2 2 0 01-2-2V18a2 2 0 012-2zm6 5v6m-3-3h6" fill="none" stroke="var(--on-crimson)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
