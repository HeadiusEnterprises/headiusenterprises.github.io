          <span class="badge badge--teal">JAX Innovators 2012</span>
          <span class="badge">Oracle Groundbreaker 2018</span>
        <% end %>
      <% end %>
      <%= render Card.new do %>
        <pre><code class="highlight"><span class="k">class</span> <span class="nc">SondraRadkeNutter</span> <span class="no">&lt; Human</span>
  <span class="c"># President</span></code></pre>
        <p>
          25 years of professional education and organisational leadership. Sondra has guided teams through transitions across the country and through changing structures, applying detailed organisation and follow-through to every challenge.
