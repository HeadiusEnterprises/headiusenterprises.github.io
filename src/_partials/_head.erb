<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<% resource_title = strip_html(strip_newlines(title)) %>
<title><% if resource_title != "Index" %><%= resource_title %> | <%= metadata.title %><% else %><%= metadata.title %> &mdash; <%= metadata.tagline %><% end %></title>

<meta name="description" content="<%= metadata.description %>" />
<% if defined?(resource) && resource&.data&.canonical_url %>
<link rel="canonical" href="<%= resource.data.canonical_url %>" />
<% end %>

<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="msapplication-TileColor" content="#0e0b0c" />
<meta name="theme-color" content="#0e0b0c" />

<link rel="alternate" type="application/atom+xml" title="<%= metadata.title %>" href="<%= relative_url '/feed.xml' %>" />
<link rel="stylesheet" href="<%= asset_path :css %>" />
<script src="<%= asset_path :js %>" defer></script>
<%= live_reload_dev_js %>

<script>
  // Apply saved theme immediately to prevent flash of wrong theme
  (function() {
    var saved = localStorage.getItem('headius-theme') || 'auto';
    var theme;
    if (saved === 'auto') {
      theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    } else {
      theme = saved;
    }
    if (theme !== 'dark') {
      document.documentElement.setAttribute('data-theme', theme);
    }
  })();
</script>
